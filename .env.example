# Sailor - Environment Variables Example
# Copy this file to .env and configure with your own values

# ======================
# Database Configuration
# ======================
# MySQL connection details (used by backend)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=sailor
MYSQL_USER=sailor
MYSQL_PASSWORD=your_secure_password_here

# ======================
# JWT Configuration
# ======================
# Secret key for signing JWT tokens (change in production!)
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-min-256-bits-for-hs256-algorithm-change-in-production
JWT_ACCESS_TOKEN_VALIDITY=900000      # 15 minutes in milliseconds
JWT_REFRESH_TOKEN_VALIDITY=604800000  # 7 days in milliseconds

# ======================
# Application Settings
# ======================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ======================
# Notes
# ======================
# For development with Docker, the default values in docker-compose.yml are sufficient.
# For production deployment:
#   1. Generate a strong JWT_SECRET: openssl rand -base64 64
#   2. Use a strong MYSQL_PASSWORD
#   3. Set SPRING_PROFILES_ACTIVE=prod
#   4. Consider using environment-specific configuration files
