# Backend Environment Variables Example
# Copy this file to .env and configure with your own values

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/sailor
SPRING_DATASOURCE_USERNAME=sailor
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-min-256-bits-for-hs256-algorithm-change-in-production
JWT_ACCESS_TOKEN_VALIDITY=900000      # 15 minutes
JWT_REFRESH_TOKEN_VALIDITY=604800000  # 7 days

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Note: For Docker deployment, these values are configured in docker-compose.yml
